<footer id="footer">
  <% if (theme.sidebar === 'bottom'){ %>
    <%- partial('_partial/sidebar') %>
  <% } %>
  <div id="footer-info" class="inner">
    <% if (theme.copyright){ %>
      <%- render(theme.copyright, 'pug'); %>
    <% } %>
    <strong><%= theme.author || config.author || config.title %></strong>
    <span>记录 AI 的现在，理解技术的下一步。</span>
    <small>&copy; <%= date(new Date(), 'YYYY') %> · <a href="<%- url_for('/atom.xml') %>">RSS 订阅</a> &amp; <a href="<%- url_for('/sitemap.xml') %>">Sitemap</a></small>
  </div>
</footer>
