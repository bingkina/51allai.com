<div class="widget-wrap">
  <div class="info-card">
    <div class="avatar">
      <% if (theme.avatar) { %>
        <image src=<%- url_for(theme.avatar) %>></image>
      <% } %>
      <div class="img-dim"></div>
    </div>
    <div class="info">
      <div class="username"><%- theme.author || config.author %> </div>
      <div class="dot"></div>
      <div class="subtitle"><%- theme.subtitle || config.subtitle %> </div>
      <div class="link-list">
        <% for(let item of theme.links) { %>
          <a class="link-btn" href="<%- item.url %>" title="<%- item.name %>">
            <% if (/\.(png|jpg|jpeg|gif|svg|webp|ico)$/i.test(item.icon)) { %>
              <img class="link-icon-img" src="<%- url_for(item.icon) %>" alt="<%- item.name %>">
            <% } else { %>
              <i class="<%- item.icon %>"></i>
            <% } %>
          </a>
        <% } %> 
      </div>  
    </div>
  </div>
</div>
