# 复制这个文件为 .env，填入真实的值后再使用：
#   cp .env.example .env
#
# .env 已在 .gitignore 中忽略，不会被提交。

# Algolia 配置（hexo-algoliasearch 读取的环境变量名）
# 到 Algolia 控制台 > API Keys 处获取 adminApiKey，用于 hexo algolia 写入索引
ALGOLIA_ADMIN_API_KEY=

# 可选：覆盖 _config.yml 中的 Algolia 配置（通常不需要）
# ALGOLIA_APP_ID=DB7LNOTMKC
# ALGOLIA_INDEX_NAME=51allai
